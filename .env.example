# ============================================================
#  toss-dashboard — 시크릿 템플릿
# ============================================================
#  사용법:
#    cp .env.example .env
#    chmod 600 .env
#    (에디터로 .env 를 열어 값을 채우세요)
#
#  ⚠️ 이 값들을 채팅·이슈·커밋에 붙여넣지 마세요.
#     .env 는 .gitignore 로 차단되어 있습니다.
#
#  DB 접속 정보는 여기 없습니다 — Vercel 이 관리하는
#  web/.env.local 에 자동으로 들어갑니다. 갱신하려면:
#    cd web && vercel env pull .env.local
# ============================================================


# ── 토스증권 Open API ──────────────────────────────────────
#  발급: 토스증권 WTS(PC 웹) → 설정 → Open API
#  ⚠️ client 당 유효 토큰은 1개. 재발급 시 기존 토큰이
#     즉시 무효화되므로 여러 프로세스가 각자 발급하면 안 됩니다.
#     (토큰 발급은 워커의 단일 지점에서만 수행)
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=

# 계좌 식별자. 워커가 GET /api/v1/accounts 로 1회 조회해
# 캐시하므로 비워둬도 됩니다 (ACCOUNT 그룹은 1 TPS 제한).
TOSS_ACCOUNT_SEQ=


# ── 주문 실행 안전장치 ─────────────────────────────────────
#  false = 드라이런. 주문 페이로드까지 조립·검증하지만
#          실제 POST /api/v1/orders 는 호출하지 않고 로그만 남김.
#  ⚠️ true 로 바꾸는 순간 실제 돈이 나갑니다.
#     백테스팅 검증을 통과하기 전에는 false 로 두세요.
EXECUTE_ORDERS=false

# 자체 킬스위치 (드라이런 해제 후에도 적용)
MAX_ORDERS_PER_DAY=10
MAX_ORDER_AMOUNT_KRW=100000


# ── 감성분석 ───────────────────────────────────────────────
#  SENTIMENT_BACKEND: gemini | local | disabled
#   - gemini: Gemini API 호출 (디스크 0, 한국어 은어에 강함)
#   - local : 로컬 모델 (torch+모델 약 3~4GB 디스크 필요)
SENTIMENT_BACKEND=gemini

#  발급: https://aistudio.google.com/apikey
#  (Google 계정 로그인 → "Create API key" → 프로젝트 선택)
GEMINI_API_KEY=

#  gemini-flash-lite-latest : 최저비용, 대량 단순 분류에 최적
#  공식 설명 — "Our most cost-efficient model, optimized for
#  high-volume agentic tasks, translation, and simple data processing."
#  유료 기준 $0.25/1M 입력, $1.50/1M 출력 (Batch 사용 시 50% 할인)
#  ※ Flash / Flash-Lite 계열은 무료 티어가 존재합니다.
#    실제 RPM/TPD 한도는 https://aistudio.google.com/rate-limit 에서 확인
SENTIMENT_MODEL=gemini-flash-lite-latest

# 1회 요청에 묶을 게시글 수 (시스템 프롬프트 비용 분산)
SENTIMENT_BATCH_SIZE=20


# ── 외부 데이터 소스 ───────────────────────────────────────
# DART OpenAPI (금감원 공식·무료) — 펀더멘털(PER/PBR/EPS)
#   발급: opendart.fss.or.kr
DART_API_KEY=

# 뉴스 — 네이버 검색 API (Client ID/Secret 필요)
#   발급: https://developers.naver.com/apps/#/register
#   → 애플리케이션 등록 → "검색" API 선택 → ID/Secret 발급
#   요청 헤더: X-Naver-Client-Id / X-Naver-Client-Secret
#   ⚠️ 위 헤더명·쿼터는 developers.naver.com 접근이 차단되어
#      직접 확인하지 못했습니다. 발급 화면에서 재확인하세요.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 커뮤니티 — Reddit (client_id / secret / user_agent 3개 모두 필수)
#   발급: https://old.reddit.com/prefs/apps/
#   → "create another app" → 타입 script 선택 →
#      client_id 는 앱 이름 아래 14자 이상 문자열,
#      secret 은 27자 이상 문자열
#   ⚠️ user_agent 는 Reddit 이 필수로 요구합니다. 형식 예:
#      "toss-dashboard/0.1 by u/본인계정명"
#      기본값 그대로 두면 차단될 수 있으니 계정명을 넣으세요.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=toss-dashboard/0.1 by u/YOUR_REDDIT_USERNAME

# 커뮤니티 — X(트위터). 유료 티어 비용이 커서 후순위 권장
#   발급: https://developer.x.com/en/portal/dashboard
X_BEARER_TOKEN=


# ── 폴링 주기 (초) ─────────────────────────────────────────
#  MARKET_DATA 그룹은 10 TPS 공유(호가·현재가·체결·상하한가).
#  prices 는 200종목 일괄 조회라 1회면 관심종목 전체를 덮습니다.
POLL_PRICES_SEC=1
POLL_ORDERBOOK_SEC=1
POLL_TRADES_SEC=2


# ── 셀프호스팅 필수 ──────────────────────────────────────
# 마스터 키 생성:  python3 worker/crypto.py --genkey
#  ⚠️ 한 번 정하면 바꾸지 말 것. 바꾸면 저장된 자격증명을 복호화할 수 없다.
CREDENTIAL_MASTER_KEY=
SESSION_PEPPER=
INTERNAL_API_TOKEN=
# 배포 시 워커(검증 프록시) URL. 로컬 단독 실행이면 비워둔다.
WORKER_API_URL=
